# ==========================================
# Duck Analytics — Variáveis de produção
# ==========================================
# Copie este arquivo para .env e ajuste os valores.
# Usado pelo docker-compose.prod.yml.
#
#   cp .env.production.example .env
#   docker compose -f docker-compose.prod.yml up -d

# ---------- Segurança ----------
# Segredo para assinatura de tokens JWT (troque por algo forte!)
JWT_SECRET=troque-por-um-segredo-forte

# Chave AES-256-GCM para cifrar dados sensíveis (exatamente 64 caracteres hex).
# Gere com:  openssl rand -hex 32
ENCRYPTION_KEY=700b29a4505d5255501ead237d12277994082d4b129272ce7c02edb1868e080b

# ---------- Banco de dados ----------
# Senha do PostgreSQL (usada tanto no container quanto na connection string).
POSTGRES_PASSWORD=duck

# ---------- Rede ----------
# Porta exposta no host (acessa o frontend + API por essa porta).
PORT=3000
